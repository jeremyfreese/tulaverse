m <- lm(mpg ~ cyl + wt, data = mtcars)
tula(m)
tula(m, wide = TRUE)
tula(m, width = 120)

m2 <- glm(am ~ cyl + wt, data = mtcars, family = binomial)
tula(m2)

tula(mtcars)
tula(mtcars, sep = 3, median = TRUE)

tula(mpg, data = mtcars)
tula(c(mpg, wt, hp), data = mtcars)

}
